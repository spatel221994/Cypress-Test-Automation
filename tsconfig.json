{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "module": "Node16",
    "moduleResolution": "node16",
    "types": [
      "cypress",
      "node"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": "."
  },
  "include": [
    "cypress/**/*.ts",
    "cypress.config.ts"
  ]
}